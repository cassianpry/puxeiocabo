generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id              Int                 @id @default(autoincrement())
  email           String              @unique
  passwordHash    String
  emailVerifiedAt DateTime?
  shortId         BigInt?             @unique
  fighter         Fighter?            @relation(fields: [shortId], references: [shortId])
  refreshToken    String?
  role            String              @default("user")
  createdAt       DateTime            @default(now())
  consentGivenAt  DateTime?
  verificationTokens VerificationToken[]
}

model VerificationToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  type      String
  accountId Int
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  metadata  String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([accountId])
}

model ContactInquiry {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model Fighter {
  shortId         BigInt   @id @unique
  fighterId       String?
  platformId      Int
  platformName    String
  platformTool    String
  circleName      String?
  account         Account?
  reportsMade     Report[] @relation("Reporter")
  reportsReceived Report[] @relation("Reported")
}

model BugReport {
  id          Int      @id @default(autoincrement())
  subject     String
  description String
  status      String   @default("open")
  createdAt   DateTime @default(now())
}

model Report {
  id             Int      @id @default(autoincrement())
  reporterId     BigInt
  reportedId     BigInt
  reporter       Fighter  @relation("Reporter", fields: [reporterId], references: [shortId])
  reported       Fighter  @relation("Reported", fields: [reportedId], references: [shortId])
  proofImagePath String
  comment        String
  adminComment   String?
  exifData       String?
  aiSuspicious   Boolean  @default(false)
  aiReason       String?
  createdAt      DateTime @default(now())
  status         String   @default("pending")
}
